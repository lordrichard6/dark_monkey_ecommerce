# ============================================================
# Dark Monkey — Environment Variables Sample
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any real secrets.
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
# Local: run `supabase start` then `supabase status`
# Cloud: Supabase Dashboard → Settings → API
# IMPORTANT: NEXT_PUBLIC_SUPABASE_ANON_KEY must be the PUBLISHABLE key (not service_role)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Required for admin panel (products, orders, discounts, Printful sync)
# Local: `supabase status` → "Secret key"
# Cloud: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Stripe ─────────────────────────────────────────────────
# Test keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ─── Printful ───────────────────────────────────────────────
# API token: https://www.printful.com/dashboard/settings/api
PRINTFUL_API_TOKEN=your_printful_api_token_here
PRINTFUL_STORE_ID=your_printful_store_id_here
PRINTFUL_WEBHOOK_SECRET=your_printful_webhook_secret_here
# PRINTFUL_DEFAULT_PRINT_URL=https://example.com/print-placeholder.png

# ─── Upstash Redis (rate limiting) ──────────────────────────
# Create free database: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# ─── Resend (transactional email) ───────────────────────────
# API key: https://resend.com/api-keys
# Use a verified domain for RESEND_FROM in production
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=orders@dark-monkey.ch
ADMIN_ALERT_EMAIL=admin@dark-monkey.ch

# ─── Sentry (error tracking) ────────────────────────────────
# Project settings: https://sentry.io → Settings → Projects → [project] → Client Keys
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx
# SENTRY_DSN is typically auto-loaded via sentry.*.config.ts; set here if needed
# SENTRY_DSN=https://xxxx@o0000000.ingest.sentry.io/0000000

# ─── Google Analytics 4 ─────────────────────────────────────
# Measurement ID from GA4 → Admin → Data Streams → Web → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Cloudflare Turnstile (CSRF / bot protection) ───────────
# Keys: https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# ─── Web Push Notifications (VAPID) ─────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# ─── App URL ─────────────────────────────────────────────────
# Used for emails, canonical URLs, and OG metadata
# Local: http://localhost:3000
# Production: https://www.dark-monkey.ch
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron / Automation ──────────────────────────────────────
# Random secret to authorize cron job calls
# Usage: GET /api/cron/abandoned-cart  Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your_random_secret_here
REVALIDATE_SECRET=your_revalidate_secret_here
